# GCP project used for BigQuery billing
GCP_PROJECT=your-gcp-project-id
# Region where the BQ Studio notebook lives
GCP_LOCATION=us-central1
# Dataform repository ID for the notebook (from the BQ Studio URL)
BQ_NOTEBOOK_REPO_ID=your-notebook-repo-uuid
# Local filename for the notebook
BQ_NOTEBOOK_FILE=cancer_multiomics_eda.ipynb
# Author info used when pushing changes to BQ Studio
SYNC_AUTHOR_NAME=your-name
SYNC_AUTHOR_EMAIL=you@example.com
